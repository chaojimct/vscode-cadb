{
  "name": "vscode-cadb",
  "displayName": "vscode-cadb",
  "description": "Powerful database management VSCode plugin!",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "datasource",
          "title": "CADB",
          "icon": "./resources/icons/logo.svg"
        }
      ],
      "panel": [
        {
          "id": "query",
          "title": "查询",
          "icon": "$(search-sparkle)"
        }
      ]
    },
    "views": {
      "datasource": [
        {
          "id": "datasource",
          "name": "数据源",
          "icon": "$(database)",
          "contextualTitle": "Datasource Explorer"
        }
      ],
      "query": [
        {
          "type": "webview",
          "id": "query",
          "name": "查询",
          "icon": "$(search-sparkle)",
          "contextualTitle": "Query Result"
        }
      ]
    },
    "commands": [
      {
        "command": "cadb.datasource.add",
        "title": "新建项",
        "icon": "$(add)"
      },
      {
        "command": "cadb.datasource.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "cadb.datasource.search",
        "title": "搜索数据源"
      },
      {
        "command": "cadb.datasource.edit",
        "title": "编辑",
        "icon": "$(edit)"
      },
      {
        "command": "cadb.datasource.filterEntry",
        "title": "过滤显示",
        "icon": "$(cursor)"
      },
      {
        "command": "cadb.collection.useDatabase",
        "title": "使用",
        "icon": "$(cursor)"
      },
      {
        "command": "cadb.datasource.copyConnection",
        "title": "复制",
        "icon": "$(copy)"
      },
      {
        "command": "cadb.datasource.copyConnectionAddress",
        "title": "仅连接地址",
        "icon": "$(attach)"
      },
      {
        "command": "cadb.datasource.copyCredentials",
        "title": "仅用户名密码",
        "icon": "$(attach)"
      },
      {
        "command": "cadb.datasource.copyFullConnection",
        "title": "完整连接",
        "icon": "$(attach)"
      },
      {
        "command": "cadb.redis.pubsub",
        "title": "Pub/Sub",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cadb.file.execute",
        "title": "执行",
        "icon": "$(play)"
      },
      {
        "command": "cadb.file.rename",
        "title": "重命名",
        "icon": "$(rename)"
      },
      {
        "command": "cadb.file.delete",
        "title": "删除",
        "icon": "$(close)"
      },
      {
        "command": "cadb.delete",
        "title": "删除",
        "icon": "$(close)"
      },
      {
        "command": "cadb.notebook.new",
        "title": "新建 Notebook",
        "icon": "$(new-file)"
      },
      {
        "command": "cadb.sql.selectDatabase",
        "title": "选择数据库",
        "icon": "$(database)"
      },
      {
        "command": "cadb.sql.selectTable",
        "title": "选择表",
        "icon": "$(file)"
      },
      {
        "command": "cadb.notebook.showDatabaseStatus",
        "title": "显示数据库状态",
        "icon": "$(info)"
      },
      {
        "command": "cadb.sql.run",
        "title": "执行 SQL",
        "icon": "$(play)"
      },
      {
        "command": "cadb.sql.explain",
        "title": "解释 SQL",
        "icon": "$(search)"
      }
    ],
    "notebooks": [
      {
        "type": "cadb.sqlNotebook",
        "displayName": "SQL Notebook",
        "selector": [
          {
            "filenamePattern": "*.jsql"
          }
        ],
        "priority": "default"
      }
    ],
    "fileAssociations": [
      {
        "pattern": "*.jsql",
        "scheme": "file"
      },
      {
        "pattern": "*.sql",
        "scheme": "file"
      }
    ],
    "notebookRenderer": [
      {
        "id": "cadb.sql-notebook-renderer",
        "displayName": "SQL Notebook Renderer",
        "mimeTypes": [
          "application/x.sql-result",
          "application/x.sql-error"
        ],
        "entrypoint": "./resources/notebook/renderer.js"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cadb.datasource.refresh",
          "when": "view == datasource",
          "group": "navigation"
        },
        {
          "command": "cadb.datasource.add",
          "when": "view == datasource",
          "group": "navigation"
        },
        {
          "command": "cadb.notebook.new",
          "when": "view == datasource",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cadb.datasource.refresh",
          "when": "view == datasource && !(viewItem =~ /Type$/)",
          "group": "inline"
        },
        {
          "command": "cadb.datasource.edit",
          "when": "view == datasource && !(viewItem =~ /Type$/) && viewItem != folder",
          "group": "inline"
        },
        {
          "command": "cadb.datasource.add",
          "when": "view == datasource && (viewItem =~ /Type$/ || viewItem == folder)",
          "group": "inline"
        },
        {
          "command": "cadb.datasource.filterEntry",
          "when": "view == datasource && (viewItem == datasourceType || viewItem == collectionType)",
          "group": "context"
        },
        {
          "command": "cadb.collection.useDatabase",
          "when": "view == datasource && viewItem == collection",
          "group": "context"
        },
        {
          "command": "cadb.redis.pubsub",
          "when": "view == datasource && viewItem == datasource",
          "group": "context"
        },
        {
          "submenu": "cadb.datasource.copyConnectionSubmenu",
          "when": "view == datasource && viewItem == datasource",
          "group": "context"
        },
        {
          "command": "cadb.file.execute",
          "when": "view == datasource && viewItem == file",
          "group": "context"
        },
        {
          "command": "cadb.file.rename",
          "when": "view == datasource && viewItem == file",
          "group": "context"
        },
        {
          "command": "cadb.file.delete",
          "when": "view == datasource && viewItem == file",
          "group": "context"
        },
        {
          "command": "cadb.delete",
          "when": "view == datasource && !(viewItem =~ /Type$/) && viewItem != file",
          "group": "context"
        }
      ],
      "cadb.datasource.copyConnectionSubmenu": [
        {
          "command": "cadb.datasource.copyConnectionAddress"
        },
        {
          "command": "cadb.datasource.copyCredentials"
        },
        {
          "command": "cadb.datasource.copyFullConnection"
        }
      ],
      "datasource/context": [],
      "notebook/toolbar": [
        {
          "command": "cadb.sql.selectDatabase",
          "when": "notebookType == cadb.sqlNotebook",
          "group": "navigation"
        },
        {
          "command": "cadb.sql.selectTable",
          "when": "notebookType == cadb.sqlNotebook",
          "group": "navigation"
        },
        {
          "command": "cadb.notebook.showDatabaseStatus",
          "when": "notebookType == cadb.sqlNotebook",
          "group": "status"
        }
      ]
    },
    "submenus": [
      {
        "id": "cadb.datasource.copyConnectionSubmenu",
        "label": "复制"
      }
    ],
    "configuration": {
      "title": "CADB",
      "properties": {
        "cadb.sqlNotebook.fontFamily": {
          "type": "string",
          "default": "Consolas, Monaco, 'Courier New', monospace",
          "description": "SQL Notebook 编辑器字体"
        },
        "cadb.sqlNotebook.fontSize": {
          "type": "number",
          "default": 13,
          "minimum": 8,
          "maximum": 24,
          "description": "SQL Notebook 编辑器字体大小（像素）"
        },
        "cadb.sqlNotebook.lineHeight": {
          "type": "number",
          "default": 1.5,
          "minimum": 1,
          "maximum": 3,
          "description": "SQL Notebook 编辑器行高"
        }
      }
    },
    "keybindings": [
      {
        "command": "cadb.datasource.search",
        "key": "ctrl+f",
        "when": "view == datasource"
      },
      {
        "command": "cadb.datasource.search",
        "key": "cmd+f",
        "when": "view == datasource"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/mysql": "^2.15.27",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@vscode/codicons": "^0.0.44",
    "dayjs": "^1.11.19",
    "jquery": "^3.7.1",
    "layui": "^2.13.2",
    "monaco-editor": "^0.55.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.15.3",
    "redis": "^5.10.0",
    "tabulator-tables": "^6.3.1"
  }
}
