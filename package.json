{
    "name": "vscode-cadb",
    "displayName": "vscode-cadb",
    "publisher": "codingsoul",
    "description": "Powerful database management VSCode plugin!",
    "version": "0.3.0",
    "engines": {
        "vscode": "^1.104.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/caoaolong/vscode-cadb.git"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:sql",
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "icon": "logo.png",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "cadb-datasource",
                    "title": "CADB",
                    "icon": "./resources/icons/logo.png"
                }
            ],
            "panel": [
                {
                    "id": "query",
                    "title": "查询",
                    "icon": "$(search-sparkle)"
                }
            ]
        },
        "views": {
            "cadb-datasource": [
                {
                    "id": "cadb-datasource-tree",
                    "name": "数据源",
                    "icon": "$(database)",
                    "contextualTitle": "CADB 数据源"
                }
            ],
            "query": [
                {
                    "type": "webview",
                    "id": "query",
                    "name": "查询",
                    "icon": "$(search-sparkle)",
                    "contextualTitle": "Query Result"
                }
            ]
        },
        "commands": [
            {
                "command": "cadb.datasource.add",
                "title": "新建项",
                "icon": "$(add)"
            },
            {
                "command": "cadb.datasource.new",
                "title": "新建数据源",
                "icon": "$(add)"
            },
            {
                "command": "cadb.drivers.manage",
                "title": "管理数据库驱动",
                "icon": "$(extensions)"
            },
            {
                "command": "cadb.connectionGroups.manage",
                "title": "管理连接分组",
                "icon": "$(list-tree)"
            },
            {
                "command": "cadb.datasource.refresh",
                "title": "刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "cadb.datasource.focus",
                "title": "打开数据源视图",
                "icon": "$(list-tree)"
            },
            {
                "command": "cadb.datasource.search",
                "title": "搜索数据源"
            },
            {
                "command": "cadb.grid.toggleSidePanel",
                "title": "切换表格右侧工具栏（表格内 Windows/Linux：Ctrl+F；macOS：⌘F）"
            },
            {
                "command": "cadb.datasource.edit",
                "title": "编辑",
                "icon": "$(edit)"
            },
            {
                "command": "cadb.datasource.rename",
                "title": "重命名",
                "icon": "$(pencil)"
            },
            {
                "command": "cadb.datasource.filterEntry",
                "title": "过滤显示",
                "icon": "$(cursor)"
            },
            {
                "command": "cadb.oss.download",
                "title": "下载",
                "icon": "$(cloud-download)"
            },
            {
                "command": "cadb.oss.cache.clear",
                "title": "清除 OSS 临时缓存"
            },
            {
                "command": "cadb.collection.useDatabase",
                "title": "使用",
                "icon": "$(cursor)"
            },
            {
                "command": "cadb.datasource.toggleConnection",
                "title": "打开/关闭 连接",
                "icon": "$(plug)"
            },
            {
                "command": "cadb.datasource.copyTreeItemName",
                "title": "复制名称",
                "icon": "$(copy)"
            },
            {
                "command": "cadb.datasource.copyConnection",
                "title": "复制",
                "icon": "$(copy)"
            },
            {
                "command": "cadb.datasource.copyConnectionAddress",
                "title": "仅连接地址",
                "icon": "$(attach)"
            },
            {
                "command": "cadb.datasource.copyCredentials",
                "title": "仅用户名密码",
                "icon": "$(attach)"
            },
            {
                "command": "cadb.datasource.copyFullConnection",
                "title": "完整连接",
                "icon": "$(attach)"
            },
            {
                "command": "cadb.redis.pubsub",
                "title": "Pub/Sub",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "cadb.file.execute",
                "title": "执行",
                "icon": "$(play)"
            },
            {
                "command": "cadb.file.rename",
                "title": "重命名",
                "icon": "$(rename)"
            },
            {
                "command": "cadb.file.delete",
                "title": "删除",
                "icon": "$(close)"
            },
            {
                "command": "cadb.delete",
                "title": "删除",
                "icon": "$(close)"
            },
            {
                "command": "cadb.sql.selectDatabase",
                "title": "选择数据库",
                "icon": "$(database)"
            },
            {
                "command": "cadb.sql.run",
                "title": "执行 SQL",
                "icon": "$(play)"
            },
            {
                "command": "cadb.sql.runCurrent",
                "title": "运行当前语句",
                "icon": "$(debug-step-over)"
            },
            {
                "command": "cadb.sql.runLine",
                "title": "运行当前行",
                "icon": "$(play)"
            },
            {
                "command": "cadb.sql.runSelection",
                "title": "运行选中 SQL",
                "icon": "$(run-selection)"
            },
            {
                "command": "cadb.sql.runAll",
                "title": "运行全部 SQL",
                "icon": "$(play-circle)"
            },
            {
                "command": "cadb.sql.explain",
                "title": "解释 SQL",
                "icon": "$(search)"
            },
            {
                "command": "cadb.sql.runFile",
                "title": "运行 SQL 文件",
                "icon": "$(play)"
            },
            {
                "command": "cadb.scanDbConnections",
                "title": "扫描数据库连接",
                "icon": "$(search)"
            },
            {
                "command": "cadb.quickQuery",
                "title": "快捷查询",
                "icon": "$(search-sparkle)"
            },
            {
                "command": "cadb.quickExecuteSql",
                "title": "快速执行 SQL…",
                "icon": "$(run)"
            },
            {
                "command": "cadb.quickExecuteSqlFromHistory",
                "title": "从快速执行历史中选择并执行…",
                "icon": "$(history)"
            },
            {
                "command": "cadb.hover.openTableData",
                "title": "进入表数据"
            },
            {
                "command": "cadb.hover.editTable",
                "title": "表编辑",
                "icon": "$(edit-sparkle)"
            },
            {
                "command": "cadb.ai.openChat",
                "title": "AI 数据库助手",
                "icon": "$(hubot)"
            }
        ],
        "fileAssociations": [
            {
                "pattern": "*.sql",
                "scheme": "file"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "cadb.datasource.refresh",
                    "when": "view =~ /datasource/",
                    "group": "navigation"
                },
                {
                    "command": "cadb.datasource.new",
                    "when": "view =~ /datasource/",
                    "group": "navigation"
                },
                {
                    "command": "cadb.ai.openChat",
                    "when": "view =~ /datasource/",
                    "group": "navigation"
                },
                {
                    "command": "cadb.drivers.manage",
                    "when": "view =~ /datasource/",
                    "group": "navigation@9"
                },
                {
                    "command": "cadb.connectionGroups.manage",
                    "when": "view =~ /datasource/",
                    "group": "navigation@10"
                }
            ],
            "view/item/context": [
                {
                    "command": "cadb.datasource.copyTreeItemName",
                    "when": "view =~ /datasource/ && viewItem",
                    "group": "9_copy@1"
                },
                {
                    "command": "cadb.datasource.refresh",
                    "when": "view =~ /datasource/ && !(viewItem =~ /Type$/)",
                    "group": "inline"
                },
                {
                    "command": "cadb.datasource.toggleConnection",
                    "when": "view =~ /datasource/ && (viewItem == datasource || viewItem == datasourceClosed)",
                    "group": "connection@1"
                },
                {
                    "command": "cadb.datasource.edit",
                    "when": "view =~ /datasource/ && !(viewItem =~ /Type$/) && viewItem != folder && viewItem != group",
                    "group": "inline"
                },
                {
                    "command": "cadb.datasource.add",
                    "when": "view =~ /datasource/ && (viewItem =~ /Type$/ || viewItem == folder)",
                    "group": "inline"
                },
                {
                    "command": "cadb.oss.download",
                    "when": "view =~ /datasource/ && (viewItem == folder || viewItem == item)",
                    "group": "inline"
                },
                {
                    "command": "cadb.datasource.filterEntry",
                    "when": "view =~ /datasource/ && (viewItem == datasourceType || viewItem == collectionType)",
                    "group": "context"
                },
                {
                    "command": "cadb.collection.useDatabase",
                    "when": "view =~ /datasource/ && viewItem == collection",
                    "group": "context"
                },
                {
                    "command": "cadb.redis.pubsub",
                    "when": "view =~ /datasource/ && viewItem == datasource",
                    "group": "context"
                },
                {
                    "command": "cadb.datasource.rename",
                    "when": "view =~ /datasource/ && (viewItem == datasource || viewItem == datasourceClosed)",
                    "group": "context"
                },
                {
                    "submenu": "cadb.datasource.copyConnectionSubmenu",
                    "when": "view =~ /datasource/ && (viewItem == datasource || viewItem == datasourceClosed)",
                    "group": "context"
                },
                {
                    "command": "cadb.file.execute",
                    "when": "view =~ /datasource/ && viewItem == file",
                    "group": "context"
                },
                {
                    "command": "cadb.file.rename",
                    "when": "view =~ /datasource/ && viewItem == file",
                    "group": "context"
                },
                {
                    "command": "cadb.file.delete",
                    "when": "view =~ /datasource/ && viewItem == file",
                    "group": "context"
                },
                {
                    "command": "cadb.delete",
                    "when": "view =~ /datasource/ && !(viewItem =~ /Type$/) && viewItem != file && viewItem != group",
                    "group": "context"
                }
            ],
            "cadb.datasource.copyConnectionSubmenu": [
                {
                    "command": "cadb.datasource.copyConnectionAddress"
                },
                {
                    "command": "cadb.datasource.copyCredentials"
                },
                {
                    "command": "cadb.datasource.copyFullConnection"
                }
            ],
            "datasource/context": [],
            "editor/title": [
                {
                    "command": "cadb.sql.runCurrent",
                    "when": "resourceLangId == sql",
                    "group": "navigation@1"
                },
                {
                    "command": "cadb.sql.runSelection",
                    "when": "resourceLangId == sql && editorHasSelection",
                    "group": "navigation@2"
                },
                {
                    "command": "cadb.sql.runAll",
                    "when": "resourceLangId == sql",
                    "group": "navigation@3"
                }
            ],
            "editor/context": [
                {
                    "command": "cadb.sql.runCurrent",
                    "when": "resourceLangId == sql",
                    "group": "navigation@1"
                },
                {
                    "command": "cadb.sql.runSelection",
                    "when": "resourceLangId == sql && editorHasSelection",
                    "group": "navigation@2"
                },
                {
                    "command": "cadb.sql.runAll",
                    "when": "resourceLangId == sql",
                    "group": "navigation@3"
                }
            ],
            "explorer/context": [
                {
                    "command": "cadb.sql.runFile",
                    "when": "resourceExtname == .sql",
                    "group": "cadb@1"
                },
                {
                    "command": "cadb.scanDbConnections",
                    "when": "explorerResourceIsFolder || resourceScheme == file",
                    "group": "cadb@2"
                }
            ]
        },
        "submenus": [
            {
                "id": "cadb.datasource.copyConnectionSubmenu",
                "label": "复制"
            }
        ],
        "configurationDefaults": {
            "[sql]": {
                "editor.defaultFormatter": "codingsoul.vscode-cadb"
            }
        },
        "configuration": {
            "title": "CADB",
            "properties": {
                "cadb.quickExecuteSql.historyMaxEntries": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "maximum": 200,
                    "description": "通过「快速执行 SQL」（Ctrl+Alt+Q）记录的语句历史条数；列表中最上方为最新，超出后丢弃最旧记录"
                },
                "cadb.grid.pageSize": {
                    "type": "number",
                    "default": 2000,
                    "minimum": 1,
                    "maximum": 10000,
                    "description": "表格每页查询条数；亦为 SELECT 自动追加 LIMIT 时的默认条数"
                },
                "cadb.query.autoAppendSelectLimit": {
                    "type": "boolean",
                    "default": true,
                    "description": "执行 SELECT/WITH 时若语句末尾未写 LIMIT，则自动追加 LIMIT（条数见 cadb.grid.pageSize）"
                },
                "cadb.mysql.connectionPoolLimit": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "maximum": 100,
                    "description": "MySQL 连接池每个「主机+端口+账号」的最大连接数"
                },
                "cadb.ai.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "AI 服务 API Key"
                },
                "cadb.ai.baseUrl": {
                    "type": "string",
                    "default": "https://api.openai.com/v1",
                    "description": "AI 服务 Base URL（OpenAI 兼容接口）"
                },
                "cadb.ai.model": {
                    "type": "string",
                    "default": "gpt-4o",
                    "description": "AI 模型名称"
                }
            }
        },
        "keybindings": [
            {
                "command": "cadb.sql.runLine",
                "key": "ctrl+alt+enter",
                "when": "editorTextFocus && editorLangId == sql && !notebookEditorFocused && !editorHasSelection"
            },
            {
                "command": "cadb.sql.runLine",
                "key": "cmd+alt+enter",
                "when": "editorTextFocus && editorLangId == sql && !notebookEditorFocused && !editorHasSelection"
            },
            {
                "command": "cadb.sql.runSelection",
                "key": "ctrl+alt+enter",
                "when": "editorTextFocus && editorLangId == sql && editorHasSelection"
            },
            {
                "command": "cadb.sql.runSelection",
                "key": "cmd+alt+enter",
                "when": "editorTextFocus && editorLangId == sql && editorHasSelection"
            },
            {
                "command": "cadb.sql.runAll",
                "key": "ctrl+shift+enter",
                "when": "editorTextFocus && editorLangId == sql"
            },
            {
                "command": "cadb.sql.runAll",
                "key": "cmd+shift+enter",
                "when": "editorTextFocus && editorLangId == sql"
            },
            {
                "command": "cadb.datasource.search",
                "key": "ctrl+f",
                "when": "view =~ /datasource/ && !isMac"
            },
            {
                "command": "cadb.datasource.search",
                "key": "cmd+f",
                "when": "view =~ /datasource/ && isMac"
            },
            {
                "command": "cadb.quickExecuteSql",
                "key": "ctrl+alt+q"
            },
            {
                "command": "cadb.quickExecuteSql",
                "key": "cmd+alt+q",
                "when": "isMac"
            },
            {
                "command": "cadb.quickExecuteSqlFromHistory",
                "key": "ctrl+alt+a"
            },
            {
                "command": "cadb.quickExecuteSqlFromHistory",
                "key": "cmd+alt+a",
                "when": "isMac"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.104.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.1",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1",
        "webpack": "^5.103.0",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.967.0",
        "@langchain/core": "^1.1.40",
        "@langchain/openai": "^1.4.4",
        "@vscode/codicons": "^0.0.44",
        "chatarea": "^6.0.7",
        "dayjs": "^1.11.19",
        "jquery": "^3.7.1",
        "jsoneditor": "^10.4.2",
        "langchain": "^1.3.3",
        "layui": "^2.13.2",
        "marked": "^18.0.0",
        "monaco-editor": "^0.55.1",
        "mysql2": "^3.15.3",
        "redis": "^5.10.0",
        "sql-formatter": "^15.7.2",
        "tabulator-tables": "^6.3.1",
        "zod": "^4.3.6"
    }
}
